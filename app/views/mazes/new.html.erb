<section class="mx-auto max-w-7xl px-3 py-3 sm:px-4 sm:py-8">
  <style>
    .maze-collapsible-content {
      display: none;
    }

    .maze-collapsible-content.is-open {
      display: block;
    }

    .maze-grid-wrapper {
      position: relative;
      width: fit-content;
      margin: 0 auto;
      padding: 28px;
      overflow: visible;
    }

    .maze-page-shell {
      --maze-cell-size: 14px;
      --maze-cell-border-width: 1px;
      --maze-cell-border-color: #efefef;
    }

    .maze-grid {
      display: grid;
      gap: 0;
      width: fit-content;
      max-width: none;
      margin: 0 auto;
      border: 1px solid #94a3b8;
      background-color: #94a3b8;
      touch-action: manipulation;
      -webkit-user-select: none;
      user-select: none;
    }

    .maze-cell {
      position: relative;
      min-width: 0;
      background: #ffffff;
      aspect-ratio: 1 / 1;
      transition: background-color 0.15s ease;
      touch-action: manipulation;
      -webkit-user-select: none;
      user-select: none;
    }

    .maze-cell.is-perimeter {
      cursor: pointer;
    }

    .maze-cell.is-corner {
      background: #f8fafc;
      cursor: not-allowed !important;
    }

    .maze-cell.is-preview {
      background: #eef3f1 !important;
    }

    .maze-cell.is-entry-confirmed {
      background: #dbe7e2 !important;
    }

    .maze-cell.is-exit-confirmed {
      background: #efe3d4 !important;
    }

    .maze-cell.is-route-cell {
      box-shadow: inset 0 0 0 1px #93c5fd;
    }

    .maze-cell.is-route-tail {
      background: #0d9488 !important;
      box-shadow: inset 0 0 0 1px #ffffff;
    }

    .maze-page-shell[data-maze-current-mode="draw"] .maze-cell {
      cursor: crosshair;
    }

    .maze-page-shell[data-maze-current-mode="draw"] .maze-cell.is-corner {
      cursor: crosshair !important;
    }

    .maze-page-shell[data-maze-current-mode="draw"] .maze-grid,
    .maze-page-shell[data-maze-current-mode="draw"] .maze-cell {
      touch-action: none;
    }

    .maze-grid-badge {
      position: absolute;
      z-index: 10;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      padding: 4px 10px;
      border-radius: 9999px;
      border: 1px solid transparent;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.2;
      white-space: nowrap;
      pointer-events: none;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
    }

    .maze-grid-badge.is-hidden {
      display: none;
    }

    .maze-grid-badge-entry {
      background: #edf4f1;
      border-color: #c9d8d1;
      color: #496258;
    }

    .maze-grid-badge-exit {
      background: #f7efe6;
      border-color: #dccbb8;
      color: #7a5e3f;
    }

    .maze-grid-badge[data-side="top"] {
      transform: translate(-50%, -50%);
    }

    .maze-grid-badge[data-side="bottom"] {
      transform: translate(-50%, -50%);
    }

    .maze-grid-badge[data-side="left"] {
      transform: translate(-60%, -50%);
    }

    .maze-grid-badge[data-side="right"] {
      transform: translate(-40%, -50%);
    }

    .maze-cell.is-open-top::after,
    .maze-cell.is-open-bottom::after,
    .maze-cell.is-open-left::after,
    .maze-cell.is-open-right::after {
      content: "";
      position: absolute;
      background: #ffffff;
      pointer-events: none;
      z-index: 2;
    }

    .maze-cell.is-open-top::after {
      top: -2px;
      left: -1px;
      width: calc(100% + 2px);
      height: 4px;
    }

    .maze-cell.is-open-bottom::after {
      bottom: -2px;
      left: -1px;
      width: calc(100% + 2px);
      height: 4px;
    }

    .maze-cell.is-open-left::after {
      top: -1px;
      left: -2px;
      width: 4px;
      height: calc(100% + 2px);
    }

    .maze-cell.is-open-right::after {
      top: -1px;
      right: -2px;
      width: 4px;
      height: calc(100% + 2px);
    }

    .maze-secondary-button.is-active {
      border-color: #0d9488;
      background: #0d9488;
      color: #ffffff;
    }

    @media (max-width: 639px) {
      .maze-page-shell {
        --maze-cell-size: 9px;
      }

      .maze-grid-wrapper {
        padding: 14px;
        padding-top: 30px;
        padding-bottom: 30px;
      }

      .maze-grid-badge {
        min-width: 36px;
        padding: 3px 8px;
        font-size: 10px;
      }
    }

    @media (min-width: 1280px) {
      .maze-page-shell {
        grid-template-columns: 220px minmax(0, 1fr) 240px;
        align-items: start;
      }

      .maze-grid-wrapper {
        padding: 32px;
        padding-top: 40px;
      }

      .maze-grid-badge {
        min-width: 38px;
        padding: 3px 8px;
        font-size: 11px;
      }
    }
  </style>

  <div class="mb-8">
    <h2 class="m-0 text-3xl font-bold leading-tight text-slate-900 sm:text-4xl">
      Let's Make Mazes!
      <span class="mt-2 block text-lg font-semibold text-slate-600 sm:text-xl">
        - 迷路をつくる！ -
      </span>
    </h2>
    <h3 class="mt-3 text-2xl font-semibold leading-tight text-teal-700">
      Maze Editor
    </h3>
  </div>

  <div
    class="maze-page-shell grid grid-cols-1 gap-6"
    data-maze-entry-exit-root
    data-maze-rows="<%= @maze_rows %>"
    data-maze-cols="<%= @maze_cols %>"
    data-maze-preview-path="<%= maze_preview_path %>"
  >
    <main class="order-1 min-w-0 xl:order-2">
      <section class="w-full rounded-2xl border border-emerald-400 bg-white shadow-sm sm:p-6">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div class="p-4">
            <h2 class="text-xl font-bold text-slate-900">迷路エディタ</h2>
            <p class="mt-1 text-sm text-slate-600">現在の迷路：<%= @maze_rows %>行 × <%= @maze_cols %>列</p>
          </div>
        </div>

        <div class="w-full overflow-x-auto pb-2 xl:overflow-visible">
          <div class="rounded-2xl border border-emerald-400 bg-slate-50 p-1.5 sm:p-3">
            <div class="maze-grid-wrapper">
              <div
                class="maze-grid"
                data-maze-grid
                style="
                  grid-template-columns: repeat(<%= @maze_cols %>, var(--maze-cell-size));
                  grid-template-rows: repeat(<%= @maze_rows %>, var(--maze-cell-size));
                "
              >
                <% @maze_rows.times do |row| %>
                  <% @maze_cols.times do |col| %>
                    <div
                      class="maze-cell"
                      data-row="<%= row %>"
                      data-col="<%= col %>"
                      title="row: <%= row %>, col: <%= col %>"
                      style="
                        width: var(--maze-cell-size);
                        height: var(--maze-cell-size);
                        border: var(--maze-cell-border-width) solid var(--maze-cell-border-color);
                        box-sizing: border-box;
                        cursor: default;
                      "
                    ></div>
                  <% end %>
                <% end %>
              </div>

              <span
                class="maze-grid-badge maze-grid-badge-entry is-hidden"
                data-maze-entry-badge
                aria-hidden="true"
              >
                入口
              </span>

              <span
                class="maze-grid-badge maze-grid-badge-exit is-hidden"
                data-maze-exit-badge
                aria-hidden="true"
              >
                出口
              </span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <aside class="order-2 flex flex-col gap-6 xl:order-3">
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">操作パネル</h2>

        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-2">
          <button
            type="button"
            class="maze-secondary-button js-maze-mode-button inline-flex w-full items-center justify-center rounded-xl border border-slate-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-mode="entry"
            aria-pressed="false"
          >
            入口指定
          </button>

          <button
            type="button"
            class="maze-secondary-button js-maze-mode-button inline-flex w-full items-center justify-center rounded-xl border border-slate-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-mode="exit"
            aria-pressed="false"
          >
            出口指定
          </button>

          <button
            type="button"
            class="maze-secondary-button js-maze-mode-button inline-flex w-full items-center justify-center rounded-xl border border-slate-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-mode="draw"
            aria-pressed="false"
          >
            描画
          </button>

          <button
            type="button"
            class="maze-secondary-button inline-flex w-full items-center justify-center rounded-xl border border-emerald-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-undo-route
          >
            1セル戻す
          </button>

          <button
            type="button"
            class="maze-secondary-button inline-flex w-full items-center justify-center rounded-xl border border-emerald-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400 sm:col-span-2"
            data-maze-undo-stroke
          >
            描画単位で戻す
          </button>

          <button
            type="button"
            class="maze-secondary-button inline-flex w-full items-center justify-center rounded-xl border border-emerald-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400 sm:col-span-2"
            data-maze-redo-route
          >
            やり直す
          </button>

          <button
            type="button"
            class="maze-secondary-button inline-flex w-full items-center justify-center rounded-xl border border-emerald-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-slate-400 disabled:bg-slate-100 disabled:text-slate-400 sm:col-span-2"
            data-maze-clear-route
          >
            経路を消す
          </button>
        </div>

        <div class="mt-4 space-y-2">
          <div class="rounded-xl bg-slate-50 px-3 py-3 text-sm text-slate-600">
            現在モード：
            <span class="font-bold text-teal-700" data-maze-mode-label>入口指定</span>
          </div>

          <div class="rounded-xl bg-slate-50 px-3 py-3 text-sm text-slate-600">
            正解ルート：
            <span class="font-bold text-teal-700" data-maze-route-status>入口・出口待ち</span>
            ／ 通過セル数：
            <span class="font-bold text-teal-700" data-maze-route-count>0</span>
          </div>

          <div class="rounded-xl bg-slate-50 px-3 py-3 text-sm text-slate-600">
            確定データ：
            <span class="font-bold text-teal-700" data-maze-finalized-status>未確定</span>
          </div>

          <div class="rounded-xl bg-slate-50 px-3 py-3 text-sm text-slate-600">
            生成器入力：
            <span class="font-bold text-teal-700" data-maze-generator-status>未生成</span>
          </div>
        </div>

        <div class="mt-4">
          <button
            type="button"
            class="maze-secondary-button inline-flex w-full items-center justify-center rounded-xl border border-emerald-400 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-emerald-50 disabled:cursor-not-allowed disabled:border-emerald-400 disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-all-clear
          >
            全部消す
          </button>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">迷路生成パネル</h2>
        <p class="mt-2 text-sm leading-7 text-slate-600">
          描画した正解経路をもとに、迷路の問題や解答を生成するエリアです。
        </p>

        <div class="mt-4 flex flex-col gap-3">
          <button
            type="button"
            class="inline-flex w-full items-center justify-center rounded-xl bg-teal-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-generate
          >
            迷路を生成する
          </button>

          <button
            type="button"
            class="inline-flex w-full items-center justify-center rounded-xl bg-teal-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-preview
          >
            生成した迷路をプレビューページで確認
          </button>

          <button
            type="button"
            class="inline-flex w-full items-center justify-center rounded-xl bg-teal-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-400"
            data-maze-reset-generated
          >
            生成した迷路をリセット
          </button>
        </div>

        <div class="mt-4 rounded-xl bg-slate-800 p-3">
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="pl-4 text-xs font-bold text-slate-300">確定データ(JSON確認ポイント)</span>
            <button
              type="button"
              class="text-sm font-semibold text-amber-200 transition hover:text-amber-100 disabled:cursor-not-allowed disabled:text-slate-500"
              data-copy-finalized-json
              disabled
            >
              コピー
            </button>
          </div>
          <pre class="m-0 max-h-56 overflow-auto whitespace-pre-wrap wrap-break-word font-mono text-xs leading-6 text-slate-200" data-maze-finalized-json>未確定</pre>
        </div>

        <div class="mt-4 rounded-xl bg-slate-800 p-3">
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="pl-4 text-xs font-bold text-slate-300">生成器入力(JSON確認ポイント)</span>
            <button
              type="button"
              class="text-sm font-semibold text-amber-200 transition hover:text-amber-100 disabled:cursor-not-allowed disabled:text-slate-500"
              data-copy-generator-json
              disabled
            >
              コピー
            </button>
          </div>
          <pre class="m-0 max-h-56 overflow-auto whitespace-pre-wrap wrap-break-word font-mono text-xs leading-6 text-slate-200" data-maze-generator-json>未生成</pre>
        </div>
      </section>
    </aside>

    <aside class="order-3 flex flex-col gap-6 xl:order-1">
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-lg font-bold text-slate-900">♻️かんたん操作ガイド</h2>
          <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">
            はじめに確認
          </span>
        </div>

        <ol class="list-decimal space-y-2 pl-5 text-sm leading-7 text-slate-600">
          <li>🚪 [入口指定][出口指定]:<br> クリックして指定</li>
          <li>✏️ [描画]:<br> 入口から出口までつなぐ</li>
          <li>💭 [迷路を生成する]:<br> 迷路を自動生成する</li>
          <li>🔍 [プレビュー確認]:<br> できた迷路を確認する</li>
          <li>🧩 印刷や画像をダウンロードして迷路で遊ぶ</li>
          <li>♻️ シェアしてみんなで迷路で遊ぶ☺️☺️</li>
        </ol>

        <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm font-bold text-slate-700">注意事項</p>
            <label class="flex items-center gap-2 text-sm font-semibold text-slate-700" for="toggle-notes">
              <input
                id="toggle-notes"
                type="checkbox"
                class="js-collapsible-toggle"
                data-target-id="notes-content"
              >
              <span>表示</span>
            </label>
          </div>

          <div id="notes-content" class="maze-collapsible-content mt-4">
            <ul class="list-disc space-y-2 pl-5 text-sm leading-7 text-slate-600">
              <li>❌: 「入口」と「出口」は描画を開始すると変更することが出来ません😣 変更するには <b>「全部消す」</b>で初期化後、初めから作成してください。</li>
              <li>📃: 印刷サイズはA4サイズを想定して作成されます。</li>
              <li>⚠️重要: MVP版では制作した迷路の保持期間はMVP版では○○分です。</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">印刷時に迷路情報を<br>追加（任意）</h2>

        <div class="mt-4 space-y-4">
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="text-sm font-bold text-slate-700">迷路タイトル</p>
              <label class="flex items-center gap-2 text-sm font-semibold text-slate-700" for="use-maze-title">
                <input
                  id="use-maze-title"
                  type="checkbox"
                  class="js-collapsible-toggle"
                  data-target-id="maze-title-content"
                  data-enable-id="maze-title"
                >
                <span>表示</span>
              </label>
            </div>

            <div id="maze-title-content" class="maze-collapsible-content mt-4">
              <input
                id="maze-title"
                type="text"
                class="w-full rounded-xl border border-emerald-400 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200 disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-400"
                placeholder="例：イラスト迷路"
                maxlength="30"
                disabled
              >
              <p class="mt-2 text-xs leading-6 text-slate-500">半角30文字まで</p>
            </div>
          </div>

          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="text-sm font-bold text-slate-700">制作者から<br>ひとこと</p>
              <label class="flex items-center gap-2 text-sm font-semibold text-slate-700" for="use-maze-comment">
                <input
                  id="use-maze-comment"
                  type="checkbox"
                  class="js-collapsible-toggle"
                  data-target-id="maze-comment-content"
                  data-enable-id="maze-comment"
                >
                <span>表示</span>
              </label>
            </div>

            <div id="maze-comment-content" class="maze-collapsible-content mt-4">
              <textarea
                id="maze-comment"
                class="min-h-[100px] w-full rounded-xl border border-emerald-400 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200 disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-400"
                placeholder="例：ゴールまでたどりつけるかな？"
                maxlength="80"
                disabled
              ></textarea>
              <p class="mt-2 text-xs leading-6 text-slate-500">半角80文字まで</p>
            </div>
          </div>

          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <label class="flex items-start gap-3 text-sm leading-6 text-slate-700" for="use-solver-impression">
              <input id="use-solver-impression" type="checkbox" class="mt-1">
              <span class="font-semibold">ユーザー記入欄</span>
            </label>
            <p class="mt-2 text-xs leading-6 text-slate-500">
              ユーザー記入欄を用意します。
            </p>
          </div>
        </div>
      </section>
    </aside>
  </div>
</section>
