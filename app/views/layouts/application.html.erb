<!DOCTYPE html>
<html>
  <head>
    <title>Make Mazes!</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800">
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-slate-200 bg-white">
        <div class="mx-auto flex max-w-5xl items-center px-4 py-4 sm:px-6 lg:px-8">
          <h1 class="text-xl font-bold tracking-tight text-teal-700">
            ♻️ Make Mazes!
          </h1>
        </div>
      </header>

      <main class="flex-1">
        <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
          <%= yield %>
        </div>
      </main>

      <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-5xl px-4 py-4 text-sm text-slate-500 sm:px-6 lg:px-8">
          © Make Mazes!
        </div>
      </footer>
    </div>
  </body>
</html>
