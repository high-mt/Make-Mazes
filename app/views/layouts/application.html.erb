<!DOCTYPE html>
<html>
  <head>
    <title>Make Mazes!</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-layout-shell min-h-screen bg-slate-50 text-slate-800">
    <div class="flex min-h-screen flex-col">
      <header class="app-layout-chrome border-b border-slate-200 bg-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <h1 class="text-xl font-bold tracking-tight">
            <%= link_to "♻️ Make Mazes!", root_path, class: "inline-block text-teal-700 transition-colors duration-200 hover:text-teal-500" %>
          </h1>
        </div>
      </header>

      <main class="app-layout-main flex-1">
        <%= yield %>
      </main>

      <footer class="app-layout-chrome border-t border-slate-200 bg-white">
        <div class="mx-auto flex w-full max-w-6xl items-center gap-6 px-4 py-4 text-sm text-slate-600 sm:gap-8 sm:px-6 lg:px-8">
          <p>© Make Mazes!</p>
          <%= link_to "迷路をつくる！", new_maze_path, class: "inline-block font-medium text-emerald-700 transition-colors duration-200 hover:text-emerald-500" %>
        </div>
      </footer>
    </div>
  </body>
</html>
