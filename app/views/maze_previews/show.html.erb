<%
  preview_theme_map = {
    "question" => {
      label: "問題表示",
      short_label: "正解ルートが見えない問題用の迷路を表示しています。",
      icon: "🧩",
      nav_bg: "bg-emerald-100",
      nav_text: "text-emerald-900",
      nav_border: "border-emerald-300",
      nav_hover: "hover:bg-emerald-50",
      shell_bg: "bg-emerald-50",
      shell_border: "border-emerald-200",
      frame_bg: "bg-emerald-100/70",
      frame_border: "border-emerald-300",
      accent_bg: "bg-emerald-100",
      accent_text: "text-emerald-800",
      preview_border: "border-emerald-300",
      stats_bg: "bg-emerald-50",
      title: "解くための迷路を表示しています",
      lead: "解く人の視点で、正解ルートを見せない状態の迷路を確認できます。",
      subcopy: "自動生成した迷路なので、毎回迷路は変化します。"
    },
    "answer" => {
      label: "解答表示",
      short_label: "正解ルートの見える、解答用の迷路を表示しています。",
      icon: "🖍️",
      nav_bg: "bg-rose-100",
      nav_text: "text-rose-900",
      nav_border: "border-rose-300",
      nav_hover: "hover:bg-rose-50",
      shell_bg: "bg-rose-50",
      shell_border: "border-rose-200",
      frame_bg: "bg-rose-100/70",
      frame_border: "border-rose-300",
      accent_bg: "bg-rose-100",
      accent_text: "text-rose-800",
      preview_border: "border-rose-300",
      stats_bg: "bg-rose-50",
      title: "解答を確認する",
      lead: "迷路の正解ルートを確認できます。",
      subcopy: "解答表示では正解ルートを強調した迷路を表示します"
    },
    "print" => {
      label: "印刷プレビュー",
      short_label: "印刷",
      icon: "🖨️",
      nav_bg: "bg-sky-100",
      nav_text: "text-sky-900",
      nav_border: "border-sky-300",
      nav_hover: "hover:bg-sky-50",
      shell_bg: "bg-sky-50",
      shell_border: "border-sky-200",
      frame_bg: "bg-sky-100/70",
      frame_border: "border-sky-300",
      accent_bg: "bg-sky-100",
      accent_text: "text-sky-800",
      preview_border: "border-sky-300",
      stats_bg: "bg-sky-50",
      title: "印刷イメージを確認する",
      lead: "紙に出力する前の雰囲気を確認できます。エディタページで「迷路のタイトル」「制作者からひとこと」「感想欄」の設定や記入も出来ます。",
      subcopy: "あなたの作った迷路を、印刷したりダウンロードしてぜひご活用ください♻️"
    }
  }
  active_kind = @preview_kind.to_s
  active_kind = "question" unless %w[question answer print].include?(active_kind)

  current_theme = preview_theme_map[active_kind] || preview_theme_map["question"]
%>

<style>
  @media (max-width: 639px) {
    .print-page-root {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .print-layout-root {
      gap: 1rem;
    }

    .print-shell-reset {
      padding: 0.5rem;
      border-radius: 1.25rem;
    }

    .print-shell-reset-inner {
      padding: 0.75rem;
      border-radius: 1.25rem;
    }

    .print-page-shell {
      padding: 0.75rem;
      border-width: 3px;
      border-radius: 1.25rem;
    }

    .print-sheets-wrap {
      gap: 1rem;
    }

    .print-sheet {
      max-width: 100%;
      padding: 0.75rem;
      border-radius: 1rem;
    }

    .print-sheet-main {
      margin-top: 0.5rem;
      padding: 0.75rem;
    }

    [data-maze-print-title-row],
    .print-sheet-comment,
    .print-sheet-impression {
      margin-top: 0.5rem;
      padding: 0.75rem;
    }

    .print-sheet-footer {
      margin-top: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  @media print {
    @page {
      size: A4 portrait;
      margin: 0;
    }

    html,
    body {
      margin: 0 !important;
      padding: 0 !important;
      background: #ffffff !important;
      color: #111111 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .app-layout-shell {
      min-height: auto !important;
      background: #ffffff !important;
    }

    .app-layout-main {
      display: block !important;
      flex: none !important;
    }

    .app-layout-chrome {
      display: none !important;
    }

    .print-page-root {
      width: 210mm !important;
      max-width: none !important;
      margin: 0 auto !important;
      padding: 0 !important;
    }

    .print-ui-only {
      display: none !important;
    }

    .print-layout-root {
      display: block !important;
    }

    .print-shell-reset,
    .print-shell-reset-inner,
    .print-page-shell {
      background: transparent !important;
      border: 0 !important;
      box-shadow: none !important;
    }

    .print-shell-reset {
      padding: 0 !important;
    }

    .print-shell-reset-inner {
      padding: 0 !important;
      border-radius: 0 !important;
    }

    .print-page-shell {
      padding: 0 !important;
      margin: 0 !important;
      border-radius: 0 !important;
    }

    .print-sheets-wrap {
      display: block !important;
      gap: 0 !important;
      break-before: auto !important;
      break-after: auto !important;
      page-break-before: auto !important;
      page-break-after: auto !important;
    }

    .print-sheet {
      box-sizing: border-box !important;
      width: 190mm !important;
      height: 277mm !important;
      max-width: none !important;
      aspect-ratio: auto !important;
      margin: 10mm auto !important;
      padding: 8mm !important;
      border: 0.4mm solid #9ca3af !important;
      border-radius: 0 !important;
      background: #ffffff !important;
      box-shadow: none !important;
      color: #111111 !important;
      overflow: hidden !important;
      break-after: auto !important;
      page-break-after: auto !important;
      break-inside: avoid-page !important;
      page-break-inside: avoid !important;
    }

    .print-sheet + .print-sheet {
      break-before: page !important;
      page-break-before: always !important;
    }

    .print-sheet-header {
      display: none !important;
    }

    [data-maze-print-title-row],
    .print-sheet-comment,
    .print-sheet-impression,
    .print-sheet-footer {
      background: #ffffff !important;
      border-color: #9ca3af !important;
      color: #111111 !important;
      box-shadow: none !important;
    }

    .print-sheet-main {
      background: #ffffff !important;
      border-color: #111111 !important;
      padding: 4mm !important;
    }

    [data-maze-print-question-root],
    [data-maze-print-answer-root] {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      height: 100% !important;
      min-height: 0 !important;
      background: #ffffff !important;
    }

    [data-maze-print-question-root] svg,
    [data-maze-print-answer-root] svg {
      display: block !important;
      width: 100% !important;
      max-width: 100% !important;
      max-height: 100% !important;
      height: auto !important;
    }

    .maze-preview-frame-labels {
      fill: #111111 !important;
    }

    .maze-preview-wall-lines {
      stroke: #111111 !important;
    }

    .maze-answer-route-overlay {
      fill: none !important;
      opacity: 1 !important;
    }

    .maze-answer-route-overlay polyline {
      stroke: #ffaabb !important;
      fill: none !important;
    }

    .maze-answer-route-overlay circle {
      fill: #ffaabb !important;
      stroke: none !important;
    }

    .print-subcopy {
      display: none !important;
    }
  }
</style>

<section class="print-page-root mx-auto max-w-7xl px-3 py-4 sm:px-6 sm:py-8">
  <div class="space-y-4 sm:space-y-6">
    <header class="print-ui-only rounded-3.5xl border border-slate-200 bg-white px-4 py-4 shadow-sm sm:px-6 sm:py-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-3">
          <div class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-700">
            Maze Preview and Print Page
          </div>

          <div>
            <h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
              迷路のプレビューと印刷・ダウンロード
            </h2>
          </div>
        </div>

        <div class="rounded-2xl px-4 py-3 text-xl font-medium <%= current_theme[:accent_bg] %> <%= current_theme[:accent_text] %>">
          現在のモード：<span class="font-bold"><%= current_theme[:label] %></span>
        </div>
      </div>
    </header>

    <nav class="print-ui-only grid grid-cols-1 gap-2 sm:grid-cols-3 sm:gap-3">
      <%= link_to maze_preview_path(kind: "question"),
        class: [
          "group rounded-3xl border px-3 py-3 transition shadow-sm sm:px-4 sm:py-4",
          active_kind == "question" ? "bg-emerald-100 text-emerald-900 border-emerald-300 ring-2 ring-emerald-200" : "border-slate-200 bg-white text-slate-700 hover:bg-emerald-50"
        ].join(" ") do %>
        <div class="flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/70 text-xl shadow-sm">
            🧩
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold">問題</p>
            <p class="text-xs leading-5 opacity-80">問題表示</p>
          </div>
        </div>
      <% end %>

      <%= link_to maze_preview_path(kind: "answer"),
        class: [
          "group rounded-3xl border px-3 py-3 transition shadow-sm sm:px-4 sm:py-4",
          active_kind == "answer" ? "bg-rose-100 text-rose-900 border-rose-300 ring-2 ring-rose-200" : "border-slate-200 bg-white text-slate-700 hover:bg-rose-50"
        ].join(" ") do %>
        <div class="flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/70 text-xl shadow-sm">
            🖍️
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold">解答</p>
            <p class="text-xs leading-5 opacity-80">解答表示</p>
          </div>
        </div>
      <% end %>

      <%= link_to maze_preview_path(kind: "print"),
        class: [
          "group rounded-3xl border px-3 py-3 transition shadow-sm sm:px-4 sm:py-4",
          active_kind == "print" ? "bg-sky-100 text-sky-900 border-sky-300 ring-2 ring-sky-200" : "border-slate-200 bg-white text-slate-700 hover:bg-sky-50"
        ].join(" ") do %>
        <div class="flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/70 text-xl shadow-sm">
            🖨️
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold">印刷</p>
            <p class="text-xs leading-5 opacity-80">印刷プレビュー</p>
          </div>
        </div>
      <% end %>
    </nav>

    <div class="print-layout-root grid grid-cols-1 gap-4 sm:gap-6 xl:grid-cols-[minmax(0,1fr)_300px]">
      <section class="print-shell-reset rounded-3xl border p-2 sm:p-4 shadow-sm <%= current_theme[:shell_bg] %> <%= current_theme[:shell_border] %>">
        <div class="print-shell-reset rounded-[28px] border p-3 sm:p-5 <%= current_theme[:frame_bg] %> <%= current_theme[:frame_border] %>">
          <div class="print-shell-reset-inner space-y-4 rounded-3xl bg-white/90 p-3 shadow-inner sm:space-y-5 sm:p-6">
            <div class="print-ui-only flex flex-col gap-3 sm:gap-4 lg:flex-row lg:items-center lg:justify-between">
              <div class="space-y-2">
                <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-bold <%= current_theme[:accent_bg] %> <%= current_theme[:accent_text] %>">
                  <span><%= current_theme[:icon] %></span>
                  <span><%= current_theme[:label] %></span>
                </div>

                <div>
                  <h3 class="text-2xl font-bold text-slate-900">
                    <%= current_theme[:title] %>
                  </h3>
                  <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
                    <%= current_theme[:lead] %>
                  </p>
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
                生成した迷路は生成ごとに毎回変化します。<br>エディタに戻って何度でも作りなおしもできます🧩
              </div>
            </div>

            <% if active_kind == "question" || active_kind == "answer" %>
              <div class="space-y-3 sm:space-y-4">
                <div
                  data-maze-preview-root
                  class="flex min-h-72 items-center justify-start overflow-x-auto overflow-y-hidden rounded-[22px] border-4 bg-white p-3 sm:min-h-[480px] sm:p-6 <%= current_theme[:preview_border] %>"
                >
                  <div class="text-sm text-slate-500">プレビューを読み込み中...</div>
                </div>

                <div class="print-subcopy rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
                  <%= current_theme[:subcopy] %>
                </div>
              </div>
            <% else %>
              <div class="space-y-3 sm:space-y-4">
                <div class="print-page-shell rounded-3xl border-4 bg-white p-3 sm:p-6 <%= current_theme[:preview_border] %>">
                  <div class="print-sheets-wrap grid grid-cols-1 gap-4 sm:gap-6 xl:grid-cols-2">
                    <section
                      data-maze-print-sheet
                      class="print-sheet mx-auto flex w-full max-w-[420px] aspect-[210/297] flex-col rounded-[20px] border border-slate-300 bg-white p-4 sm:p-5 shadow-sm"
                    >
                      <div class="print-sheet-header mb-4 flex items-center justify-between border-b border-slate-200 pb-3">
                        <div>
                          <p class="text-[11px] font-bold tracking-[0.2em] text-slate-500">PRINT PREVIEW</p>
                          <h4 class="text-lg font-bold text-slate-900">問題用レイアウト</h4>
                        </div>
                        <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-800">
                          QUESTION
                        </span>
                      </div>

                      <div
                        data-maze-print-title-row
                        class="mb-3 rounded-xl bg-slate-50 px-4 py-3"
                      >
                        <div
                          class="flex flex-col gap-1 text-left sm:grid sm:items-center sm:justify-items-start sm:gap-x-3 sm:gap-y-1"
                          style="grid-template-columns: 88px minmax(0, 1fr) auto;"
                        >
                          <p
                            data-maze-print-title-label
                            class="shrink-0 whitespace-nowrap text-xs font-bold tracking-wide text-slate-800 sm:text-lg"
                          >
                            迷路名：
                          </p>

                          <p
                            data-maze-print-title
                            class="min-w-0 justify-self-start text-left wrap-break-word text-lg font-bold tracking-wide text-slate-800 sm:text-2xl"
                          >
                            Make Mazes!で制作した迷路
                          </p>

                          <p
                            data-maze-print-title-powered
                            class="hidden text-[11px] font-semibold text-slate-500 sm:block sm:justify-self-end sm:self-end sm:text-sm"
                          >
                            Powered by Make Mazes!
                          </p>
                        </div>
                      </div>

                      <div
                        data-maze-print-comment-row
                        class="print-sheet-comment hidden mt-2 sm:mt-3 rounded-xl border border-slate-200 bg-white px-4 py-3"
                      >
                        <div
                          class="flex flex-col gap-1 sm:grid sm:items-start sm:gap-x-3 sm:gap-y-1"
                          style="grid-template-columns: 132px minmax(0, 1fr);"
                        >
                          <p class="shrink-0 whitespace-nowrap text-xs font-semibold leading-5 text-slate-500 sm:text-sm">
                            制作者からひとこと：
                          </p>

                          <p
                            data-maze-print-comment
                            class="min-w-0 wrap-break-word text-xs leading-6 text-slate-700 sm:text-base sm:leading-7"
                          ></p>
                        </div>
                      </div>

                      <main class="print-sheet-main flex-1 mt-2 sm:mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-2 sm:p-3">
                        <div
                          data-maze-print-question-root
                          class="flex h-full items-center justify-center rounded-xl bg-white p-1.5 sm:p-2"
                        >
                          <div class="text-sm text-slate-400">
                            問題用プレビューを読み込み中...
                          </div>
                        </div>
                      </main>

                      <div
                        data-maze-print-impression-row
                        class="print-sheet-impression hidden mt-2 sm:mt-3 rounded-xl border border-slate-300 bg-white px-4 py-4"
                      >
                        <p class="text-sm font-semibold text-slate-700">解いた感想：</p>

                        <div class="mt-3 space-y-3 text-slate-400">
                          <div class="h-20 border-b border-slate-300"></div>
                        </div>
                      </div>

                      <footer class="print-sheet-footer mt-2 sm:mt-3 border-t border-slate-200 pt-2 sm:pt-3 text-xs leading-5 text-slate-500">
                        <p class="mt-1.5 sm:mt-2">
                          この印刷物は個人利用・学習利用を想定しています。無断での商用利用はご遠慮ください。
                        </p>
                        <div class="flex items-center justify-between gap-3">
                          <span>- 問題用 -</span>
                          <span>© Make Mazes! All Rights Reserved.</span>
                        </div>
                      </footer>
                    </section>

                    <section
                      data-maze-print-sheet
                      class="print-sheet mx-auto flex w-full max-w-[420px] aspect-[210/297] flex-col rounded-[20px] border border-slate-300 bg-white p-4 sm:p-5 shadow-sm"
                    >
                      <div class="print-sheet-header mb-4 flex items-center justify-between border-b border-slate-200 pb-3">
                        <div>
                          <p class="text-[11px] font-bold tracking-[0.2em] text-slate-500">PRINT PREVIEW</p>
                          <h4 class="text-lg font-bold text-slate-900">解答用レイアウト</h4>
                        </div>
                        <span class="rounded-full bg-rose-100 px-3 py-1 text-xs font-bold text-rose-800">
                          ANSWER
                        </span>
                      </div>

                      <div
                        data-maze-print-title-row
                        class="mb-3 rounded-xl bg-slate-50 px-4 py-3"
                      >
                        <div
                          class="flex flex-col gap-1 text-left sm:grid sm:items-center sm:justify-items-start sm:gap-x-3 sm:gap-y-1"
                          style="grid-template-columns: 88px minmax(0, 1fr) auto;"
                        >
                          <p
                            data-maze-print-title-label
                            class="shrink-0 whitespace-nowrap text-xs font-bold tracking-wide text-slate-800 sm:text-lg"
                          >
                            迷路名：
                          </p>

                          <p
                            data-maze-print-title
                            class="min-w-0 justify-self-start text-left wrap-break-word text-lg font-bold tracking-wide text-slate-800 sm:text-2xl"
                          >
                            Make Mazes!で制作した迷路
                          </p>

                          <p
                            data-maze-print-title-powered
                            class="hidden text-[11px] font-semibold text-slate-500 sm:block sm:justify-self-end sm:self-end sm:text-sm"
                          >
                            Powered by Make Mazes!
                          </p>
                        </div>
                      </div>

                      <div
                        data-maze-print-comment-row
                        class="print-sheet-comment hidden mt-2 sm:mt-3 rounded-xl border border-slate-200 bg-white px-4 py-3"
                      >
                        <div
                          class="flex flex-col gap-1 sm:grid sm:items-start sm:gap-x-3 sm:gap-y-1"
                          style="grid-template-columns: 132px minmax(0, 1fr);"
                        >
                          <p class="shrink-0 whitespace-nowrap text-xs font-semibold leading-5 text-slate-500 sm:text-sm">
                            制作者からひとこと：
                          </p>

                          <p
                            data-maze-print-comment
                            class="min-w-0 wrap-break-word text-xs leading-6 text-slate-700 sm:text-base sm:leading-7"
                          ></p>
                        </div>
                      </div>

                      <main class="print-sheet-main flex-1 mt-2 sm:mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-2 sm:p-3">
                        <div
                          data-maze-print-answer-root
                          class="flex h-full items-center justify-center rounded-xl bg-white p-1.5 sm:p-2"
                        >
                          <div class="text-sm text-slate-400">
                            解答用プレビューを読み込み中...
                          </div>
                        </div>
                      </main>

                      <footer class="print-sheet-footer mt-2 sm:mt-3 border-t border-slate-200 pt-2 sm:pt-3 text-xs leading-5 text-slate-500">
                        <p class="mt-1.5 sm:mt-2">
                          この印刷物は個人利用・学習利用を想定しています。無断での商用利用はご遠慮ください。
                        </p>
                        <div class="flex items-center justify-between gap-3">
                          <span>- 正解ルート確認用 -</span>
                          <span>© Make Mazes! All Rights Reserved.</span>
                        </div>
                      </footer>
                    </section>
                  </div>
                </div>

                <div class="print-subcopy rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
                  <%= current_theme[:subcopy] %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </section>

      <aside class="print-ui-only space-y-4 sm:space-y-5">
        <section class="rounded-[28px] border border-slate-200 bg-white p-4 sm:p-5 shadow-sm">
          <h3 class="text-base font-bold text-slate-900">このモードで見れること</h3>

          <div class="mt-4 rounded-2xl px-4 py-4 <%= current_theme[:stats_bg] %>">
            <p class="text-sm font-semibold <%= current_theme[:accent_text] %>">
              <%= current_theme[:label] %>
            </p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              <%= current_theme[:lead] %>
            </p>
          </div>
        </section>

        <section class="rounded-[28px] border border-slate-200 bg-white p-4 sm:p-5 shadow-sm">
          <div class="mt-3 sm:mt-4 space-y-3">
            <%= link_to "迷路エディタへ戻る",
              new_maze_path,
              class: "inline-flex w-full items-center justify-center rounded-2xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-teal-700" %>

            <% if active_kind == "print" %>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                <button
                  type="button"
                  data-maze-download-button
                  data-maze-download-kind="question"
                  class="inline-flex w-full items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
                >
                  問題用PNGをダウンロード
                </button>

                <button
                  type="button"
                  data-maze-download-button
                  data-maze-download-kind="answer"
                  class="inline-flex w-full items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
                >
                  解答用PNGをダウンロード
                </button>
              </div>

              <button
                type="button"
                data-maze-print-button
                class="inline-flex w-full items-center justify-center rounded-2xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-teal-700"
              >
                このレイアウトを印刷する
              </button>
            <% else %>
              <button
                type="button"
                data-maze-download-button
                data-maze-download-kind="<%= active_kind %>"
                class="inline-flex w-full items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
              >
                <%= active_kind == "answer" ? "解答用PNGをダウンロード" : "問題用PNGをダウンロード" %>
              </button>

              <%= link_to "印刷用レイアウトへ",
                maze_preview_path(kind: "print"),
                class: "inline-flex w-full items-center justify-center rounded-2xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-teal-700" %>
            <% end %>
          </div>

          <p class="mt-4 text-xs leading-5 text-slate-500">
            問題用 / 解答用の迷路をPNGでダウンロードできます。印刷機能はこの画面のA4レイアウトをもとに動作します。
          </p>
        </section>
      </aside>
    </div>
  </div>
</section>